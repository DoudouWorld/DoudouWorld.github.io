$block-caption
  text-decoration: none
  text-transform: uppercase
  letter-spacing: 2px
  color: color-grey
  margin-bottom: 1em
  margin-left: 5px
  line-height: 1em
  text-shadow: none
  font-weight: 600
  font-size: 0.75em
  padding-left: 12px
  position: relative
  &:before
    content: ''
    position: absolute
    left: 0
    top: 50%
    transform: translateY(-50%)
    width: 3px
    height: 12px
    background: linear-gradient(180deg, #f0883e, #f5a623)
    border-radius: 2px

$block
  background: color-card-background
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2)
  border: 1px solid color-border
  border-radius: 8px

$base-style
  h1
    font-size: 2em
    font-weight: 700
    color: #e6edf3
    margin-top: 1.2em
    &::before
      content: ''
      display: block
      width: 40px
      height: 3px
      background: linear-gradient(90deg, #f0883e, #f5a623)
      border-radius: 2px
      margin-bottom: 0.4em
  h2
    font-size: 1.5em
    font-weight: 600
    color: #e6edf3
  h3
    font-size: 1.3em
    font-weight: 600
    color: #e6edf3
  h4
    font-size: 1.2em
    font-weight: 600
    color: #e6edf3
  h5
    font-size: 1em
    font-weight: 600
    color: color-default
  h6
    font-size: 1em
    color: color-grey
    font-weight: 600
  hr
    border: none
    height: 1px
    background: linear-gradient(90deg, transparent, color-border, transparent)
    margin: 2em 0
  strong
    font-weight: bold
    color: #e6edf3
  em, cite
    font-style: italic
  sup, sub
    font-size: 0.75em
    line-height: 0
    position: relative
    vertical-align: baseline
  sup
    top: -0.5em
  sub
    bottom: -0.2em
  small
    font-size: 0.85em
  acronym, abbr
    border-bottom: 1px dotted color-border
  ul, ol, dl
    margin: 0 20px
    line-height: line-height
  ul, ol
    ul, ol
      margin-top: 0
      margin-bottom: 0
  ul
    list-style: none
    li
      position: relative
      padding-left: 1.5em
      &:before
        content: '▸'
        position: absolute
        left: 0
        color: color-accent
        font-size: 0.8em
  ol
    list-style: decimal
  dt
    font-weight: bold