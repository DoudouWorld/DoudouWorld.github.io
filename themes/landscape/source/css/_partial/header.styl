#header
  height: banner-height
  position: relative
  border-bottom: 1px solid color-border
  background: linear-gradient(135deg, #0d1117 0%, #161b22 50%, #1a1f2e 100%)
  overflow: hidden
  &:before, &:after
    content: ""
    position: absolute
    left: 0
    right: 0
    height: 60px
    pointer-events: none
  &:before
    top: 0
    background: linear-gradient(rgba(240, 136, 62, 0.03), transparent)
  &:after
    bottom: 0
    background: linear-gradient(transparent, rgba(88, 166, 255, 0.03))

#header-outer
  height: 100%
  position: relative

#header-inner
  position: relative
  overflow: visible

#banner
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  background: url(banner-url) center #0d1117
  background-size: cover
  z-index: -1
  opacity: 0.3

#header-title
  text-align: center
  height: logo-size
  position: absolute
  top: 50%
  left: 0
  margin-top: logo-size * -0.5

$logo-text
  text-decoration: none
  color: #fff
  font-weight: 400
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5)

#logo
  @extend $logo-text
  font-size: logo-size
  line-height: logo-size
  letter-spacing: 4px
  font-family: "Inter", sans-serif
  background: linear-gradient(135deg, #f0883e, #f5a623, #58a6ff)
  -webkit-background-clip: text
  -webkit-text-fill-color: transparent
  background-clip: text
  transition: transform 0.3s ease, filter 0.3s ease
  &:hover
    transform: scale(1.05)
    filter: brightness(1.2)

#subtitle
  @extend $logo-text
  font-size: subtitle-size
  line-height: subtitle-size
  letter-spacing: 1px
  color: color-grey
  font-weight: 300

#subtitle-wrap
  margin-top: subtitle-size

#main-nav
  float: left
  margin-left: -15px

$nav-link
  float: left
  color: #c9d1d9
  opacity: 0.7
  text-decoration: none
  text-shadow: none
  transition: all 0.25s ease
  display: block
  padding: 20px 15px
  position: relative
  &:hover
    opacity: 1
    color: #f0883e
  &:after
    content: ''
    position: absolute
    bottom: 0
    left: 50%
    width: 0
    height: 2px
    background: linear-gradient(90deg, #f0883e, #f5a623)
    transition: all 0.3s ease
    transform: translateX(-50%)
  &:hover:after
    width: 80%

.nav-icon
  @extend $nav-link
  text-align: center
  font-size: font-size
  width: font-size
  height: font-size
  padding: 20px 15px
  position: relative
  cursor: pointer
  &:hover
    color: color-accent
    background: rgba(240, 136, 62, 0.1)
    border-radius: 4px

.main-nav-link
  @extend $nav-link
  font-weight: 400
  letter-spacing: 0.5px
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  @media mq-mobile
    display: block

#sub-nav
  float: right
  margin-right: -15px

#search-form-wrap
  position: absolute
  top: 15px
  width: 150px
  height: 30px
  right: -150px
  opacity: 0
  transition: 0.2s ease-out
  &.on
    opacity: 1
    right: 0
  @media mq-mobile
    width: 100%
    right: -100%

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: color-background-secondary
  padding: 5px 15px
  border-radius: 15px
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.4)
  border: 1px solid color-border

.search-form-input
  border: none
  background: none
  color: color-default
  width: 100%
  font: 13px font-sans
  outline: none
  &::-webkit-search-results-decoration
  &::-webkit-search-cancel-button
    -webkit-appearance: none

.search-form-submit
  position: absolute
  top: 50%
  right: 10px
  margin-top: -7px
  font: 13px font-icon
  border: none
  background: none
  color: color-grey
  cursor: pointer
  &:hover, &:focus
    color: color-accent