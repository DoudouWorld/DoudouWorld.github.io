if sidebar is bottom
  @import "sidebar-bottom"
else
  @import "sidebar-aside"

.widget
  @extend $base-style
  line-height: line-height
  word-wrap: break-word
  font-size: 0.9em
  ul, ol
    list-style: none
    margin: 0
    ul, ol
      margin: 0 20px
    ul
      list-style: none
    ol
      list-style: decimal

.category-list-count
.tag-list-count
.archive-list-count
  padding-left: 6px
  color: color-grey
  font-size: 0.8em
  background: rgba(88, 166, 255, 0.1)
  border-radius: 10px
  padding: 1px 8px
  &:before
    content: ""
  &:after
    content: ""

.tagcloud
  a
    margin-right: 8px
    margin-bottom: 6px
    display: inline-block
    padding: 4px 12px
    background: color-tag-bg
    color: color-link
    border-radius: 20px
    font-size: 0.85em !important
    transition: all 0.25s ease
    text-decoration: none
    &:hover
      background: color-link
      color: #fff
      transform: translateY(-1px)
